{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "createdAt"]
    },
    "Server": {
      "title": "Server",
      "description": "Monitored server configuration",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "url": { "type": "string" },
        "interval": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "url", "interval", "createdAt"]
    },
    "History": {
      "title": "History",
      "description": "Polling result for a server",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "responseTime": { "type": "number" },
        "status": { "type": "string", "enum": ["online", "offline"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "timestamp", "responseTime", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/servers/{serverId}": {
      "schema": "Server",
      "description": "The servers monitored by users"
    },
    "/servers/{serverId}/history/{historyId}": {
      "schema": "History",
      "description": "Polling history for a specific server"
    }
  }
}
